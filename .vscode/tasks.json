{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake -S . -B build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake --build build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CMake: Build and Run",
      "type": "shell",
      "command": ".\\build\\orderbook.exe",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: Build",
      "problemMatcher": []
    }
  ]
}
